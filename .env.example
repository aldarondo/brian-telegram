TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Bot @-username (no leading @). Required for group chats — the bot ignores group
# messages unless this username is @-mentioned or the message is a reply to the bot.
TELEGRAM_BOT_USERNAME=

BRIAN_MCP_CLIENT_ID=your-cloudflare-service-token-client-id
BRIAN_MCP_CLIENT_SECRET=your-cloudflare-service-token-client-secret

# Required: secret for POST /push (X-Push-Secret header). /push returns 401 if unset.
PUSH_SECRET=generate-a-long-random-string-here

# Optional: Telegram webhook secret token (set via setWebhook?secret_token=...).
# If set, requests without matching X-Telegram-Bot-Api-Secret-Token are rejected.
WEBHOOK_SECRET=

# Family member Telegram IDs — JSON map of name → numeric Telegram user ID.
# Get IDs by having each person message @userinfobot on Telegram.
# Alternatively, mount config/family.json (copy from config/family.example.json).
FAMILY_TELEGRAM_IDS={"charles":"123456789","moriah":"987654321"}

SESSION_TTL_HOURS=24
MAX_TURNS=5

# Rate limiting: max messages per window per user (applies to /telegram and /push).
RATE_MAX_MESSAGES=5
RATE_WINDOW_SECONDS=60

# URL of the synology-whisper transcription service (for voice messages).
# On the Docker bridge network this is the service name; for local dev use http://localhost:8778
WHISPER_URL=http://synology-whisper:8778

# Log file settings. LOG_DIR defaults to logs/ inside the container (mount it for persistence).
LOG_DIR=/path/to/logs
LOG_MAX_MB=10
LOG_MAX_FILES=5

# No ANTHROPIC_API_KEY needed — mount ~/.claude from Brian host for subscription auth.
# See docker-compose.yml volumes section.
