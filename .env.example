TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
BRIAN_MCP_CLIENT_ID=your-cloudflare-service-token-client-id
BRIAN_MCP_CLIENT_SECRET=your-cloudflare-service-token-client-secret
SESSION_TTL_HOURS=24
MAX_TURNS=5

# URL of the synology-whisper transcription service (for voice messages).
# On the Docker bridge network this is the service name; for local dev use http://localhost:8778
WHISPER_URL=http://synology-whisper:8778

# Optional: secret header value required by POST /push (X-Push-Secret).
# Leave unset to disable auth (only safe if /push is not exposed externally).
PUSH_SECRET=

# No ANTHROPIC_API_KEY needed — mount ~/.claude from Brian host for subscription auth.
# See docker-compose.yml volumes section.
